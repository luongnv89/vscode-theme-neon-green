# --- VCS / editor / tooling ---
.git/**
.gitignore
.vscode/**
.claude/**
.gstack/**
.github/**
.pre-commit-config.yaml
.DS_Store
**/.DS_Store

# --- Source & build scripts (not needed at runtime) ---
scripts/**
examples/**
docs/**
assets/**

