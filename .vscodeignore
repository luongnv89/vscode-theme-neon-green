package-lock.json
yarn.lock

# --- Non-VS Code terminal themes (Warp / iTerm) ---
themes/warp/**
themes/**/*.itermcolors

# --- Prior packaged artifacts ---
*.vsix

# --- Markdown docs: ship only the README ---
*.md
!README.md
